  document.getElementById('email-preview-box').style.display = 'none';
}

function toggleContactManager() {
  const el = document.getElementById('contact-manager');
  el.style.display = el.style.display === 'none' ? 'block' : 'none';
  if(el.style.display === 'block') renderContactList();
}

function saveContact() {
  const school = document.getElementById('cm-school').value.trim();
  const gm     = document.getElementById('cm-gm').value.trim();
  const email  = document.getElementById('cm-email').value.trim();
  const cc     = document.getElementById('cm-cc').value.trim();
  if(!school || !email) { alert('School name and primary email are required.'); return; }
  const contacts = loadContacts();
  contacts[school] = {gm, email, cc};
  saveContacts(contacts);
  document.getElementById('cm-school').value = '';
  document.getElementById('cm-gm').value = '';
  document.getElementById('cm-email').value = '';
  document.getElementById('cm-cc').value = '';
  renderContactList();
}

function deleteContact(school) {
  if(!confirm('Remove override for ' + school + '?')) return;
  const contacts = loadContacts();
  delete contacts[school];
  saveContacts(contacts);
  renderContactList();
}

function renderContactList() {
  const custom = loadContacts();
  const el = document.getElementById('cm-list');
  
  const all = Object.assign({}, BUILTIN_CONTACTS, custom);
  const schools = Object.keys(all).sort();
  el.innerHTML = '';
  schools.forEach(school => {
    const c = all[school];
    const isCustom = !!custom[school];
    const row = document.createElement('div');
    row.style.cssText = 'display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-family:DM Mono,monospace;font-size:12px;gap:8px;flex-wrap:wrap';
    row.innerHTML = '<span style="color:var(--text);font-weight:600;min-width:160px">' + school + (isCustom ? ' <span style="color:var(--yellow);font-size:10px">custom</span>' : '') + '</span>' +
      '<span style="color:var(--muted);flex:1">' + (c.gm||'') + '</span>' +
      '<span style="color:var(--blue);flex:1">' + (c.email||'') + '</span>' +
      '<span style="color:var(--muted);flex:1">' + (c.cc||'') + '</span>' +
      (isCustom ? '<button onclick="deleteContact(' + JSON.stringify(school) + ')" style="background:none;border:1px solid var(--accent);color:var(--accent);border-radius:4px;padding:2px 8px;cursor:pointer;font-size:11px;font-family:DM Mono,monospace">Remove</button>' : '');
    el.appendChild(row);
  });
}

window.addEventListener('load', () => {
  const savedWeek = lsGet('drone_week_label');
  if(savedWeek) {
    const el = document.getElementById('email-week-label');
    if(el) el.value = savedWeek;
  }
  refreshSavedStatsList();
  refreshSchoolDropdown();
});
</script>

