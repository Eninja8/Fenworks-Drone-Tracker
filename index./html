<script>
const SCHOOL_ALIASES = {
  "kenmare-bowbells-burke co-op": "Kenmare (Burke Central)",
  "fargo south": "Fargo Public Schools",
  "fargo south high school": "Fargo Public Schools"
};
function getDisplayName(raw) {
  const lower = raw.toLowerCase().trim();
  return SCHOOL_ALIASES[lower] || raw.trim();
}
function getSortName(d) {
  return d.replace(/\s*\(.*\)/, '').trim().toLowerCase();
}

function setDonut(ringId, pct) {
  const c = 2 * Math.PI * 32;
  const f = (pct / 100) * c;
  document.getElementById(ringId).setAttribute('stroke-dasharray', `${f.toFixed(1)} ${c.toFixed(1)}`);
}
function toggleTheme() {
  const html = document.documentElement;
  const isDark = html.getAttribute('data-theme') === 'dark';
  html.setAttribute('data-theme', isDark ? 'light' : 'dark');
  document.getElementById('themeLabel').textContent = isDark ? 'Light' : 'Dark';
}
function switchTab(name, btn) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
}
function toggleRulesById(panelId, btnId) {
  const panel = document.getElementById(panelId);
  const btn = document.getElementById(btnId);
  const open = panel.style.display === 'block';
  panel.style.display = open ? 'none' : 'block';
  btn.textContent = open ? 'ℹ Rules' : '✕ Close';
}

function renderSchoolTable(schools, tbodyId, schoolCountId, pfx, matchStats) {
  const sorted = Object.entries(schools).sort((a,b) => getSortName(a[0]).localeCompare(getSortName(b[0])));
  let total=0, competed=0;
  sorted.forEach(([,d]) => { total+=d.total; competed+=d.competed; });
  const forfeited = total - competed;
  const pPct = total>0 ? Math.round(competed/total*100) : 0;
  const fPct = total>0 ? Math.round(forfeited/total*100) : 0;

  function setEl(id, val) { const el=document.getElementById(id); if(el) el.textContent=val; }

  setEl(pfx+'-total', total);
  setEl(pfx+'-competed', competed);
  setEl(pfx+'-part', pPct + '%');
  setEl(pfx+'-forfeit', fPct + '%');
  setEl(pfx+'-donut-part-pct', pPct + '%');
  setEl(pfx+'-donut-part-frac', `${competed}/${total}`);
  setDonut(pfx+'-donut-part', pPct);
  setEl(pfx+'-donut-forf-pct', fPct + '%');
  setEl(pfx+'-donut-forf-frac', `${forfeited}/${total}`);
  setDonut(pfx+'-donut-forf', fPct);

  if(matchStats) {
    const {completed:mc, forfeited:mf, double:md, byes:mb} = matchStats;
    const created = mc + mf + md + mb;
    const partDenom = total - mb;
    const partPct = partDenom>0 ? Math.round((mc*2)/partDenom*100) : 0;
    const mForfPct = created>0 ? Math.round((mf+md)/created*100) : 0;
    const pctCompeted = total>0 ? Math.round(competed/total*100) : 0;
    setEl(pfx+'-matches-created', created);
    setEl(pfx+'-matches-completed', mc);
    setEl(pfx+'-matches-forfeited', mf);
    setEl(pfx+'-matches-double', md);
    setEl(pfx+'-matches-byes', mb);
    setEl(pfx+'-pct-competed', pctCompeted + '%');
    setEl(pfx+'-pct-queued', pctCompeted + '%');
    setEl(pfx+'-part', partPct + '%');
    setEl(pfx+'-forfeit', mForfPct + '%');
    setEl(pfx+'-donut-part-pct', partPct + '%');
    setEl(pfx+'-donut-part-frac', `${mc*2}/${partDenom}`);
    setDonut(pfx+'-donut-part', partPct);
    setEl(pfx+'-donut-forf-pct', mForfPct + '%');
    setEl(pfx+'-donut-forf-frac', `${mf+md}/${created}`);
    setDonut(pfx+'-donut-forf', mForfPct);
  }

  if(pfx === 'w') {
    setEl('w-matches-completed', competed);
    setEl('w-matches-not', forfeited);
  }

  const tbody = document.getElementById(tbodyId);
  tbody.innerHTML = '';
  sorted.forEach(([name,data],idx) => {
    const {competed:comp, total:tot} = data;
    const pct = tot>0 ? comp/tot : 0;
    const pctPx = Math.round(pct*100);
    let pillClass, pillText;
    if(comp===0){pillClass='pill-none';pillText='No Show';}
    else if(comp===tot){pillClass='pill-full';pillText='All In';}
    else{pillClass='pill-partial';pillText='Partial';}
    const doubleLossFlag = data.doubleLoss ? ' <span style="color:#f5a623;font-size:11px;font-family:monospace;margin-left:6px">⚠ Double Loss</span>' : '';
    const barColor = pct===0?'var(--accent)':pct===1?'var(--green)':'var(--yellow)';
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="color:var(--muted);font-family:'DM Mono',monospace;font-size:12px">${idx+1}</td>
      <td class="school-name">${name}</td>
      <td class="fraction">${comp}<span style="color:var(--muted)">/${tot}</span></td>
      <td><div class="bar-wrap"><div class="bar-fill" style="width:${pctPx}%;background:${barColor}"></div></div><span style="font-family:'DM Mono',monospace;font-size:11px;color:var(--muted)">${pctPx}%</span></td>
      <td><span class="pill ${pillClass}">${pillText}</span>${doubleLossFlag}</td>`;
    tbody.appendChild(tr);
  });
  document.getElementById(schoolCountId).textContent = sorted.length;
}

function processWeekly() {
  const raw = document.getElementById('rawInputWeekly').value;
  const errEl = document.getElementById('errorWeekly');
  errEl.style.display = 'none';
  if(!raw.trim()){errEl.textContent='No data pasted.';errEl.style.display='block';return;}
  autoDetectWeekLabel(raw);
  const lines = raw.split('\n').map(l=>l.trim());
  const schools = {};
  let i=0;
  while(i<lines.length){
    const line=lines[i];
    if(line.startsWith('School:')){
      const displayName = getDisplayName(line.replace('School:','').trim());
      if(!schools[displayName]) schools[displayName]={competed:0,total:0};
      schools[displayName].total++;
      for(let j=i+1;j<Math.min(i+20,lines.length);j++){
        if(lines[j]==='Time'){
          for(let k=j+1;k<Math.min(j+5,lines.length);k++){
            const tl=lines[k].trim();
            if(tl==='') continue;
            if(/^\d/.test(tl)) schools[displayName].competed++;
            break;
          }
          break;
        }
      }
    }
    i++;
  }
  if(Object.keys(schools).length===0){errEl.textContent='Could not parse data.';errEl.style.display='block';return;}
  renderSchoolTable(schools,'w-tbody','w-school-count','w');
  saveAndRefreshStats(schools,'w');
  document.getElementById('results-weekly').style.display='block';
}
function clearWeekly(){
  document.getElementById('rawInputWeekly').value='';
  document.getElementById('results-weekly').style.display='none';
  document.getElementById('errorWeekly').style.display='none';
}

function processDuo() {
  const raw = document.getElementById('rawInputDuo').value;
  const errEl = document.getElementById('errorDuo');
  errEl.style.display = 'none';
  if(!raw.trim()){errEl.textContent='No data pasted.';errEl.style.display='block';return;}
  autoDetectWeekLabel(raw);

  const schoolTeams = {};

  function ensureSchool(sn) {
    if(!schoolTeams[sn]) schoolTeams[sn]={all:new Set(), competed:new Set(), doubleLoss:false};
  }

  const lines = raw.split('\n').map(l=>l.trim()).filter(l=>l!=='');

  let rankingsStart = lines.length;
  for(let i=0;i<lines.length;i++){
    if(lines[i]==='Rankings'){rankingsStart=i;break;}
  }

  const STATUS_RE = /^(COMPLETED|FORFEITED|BYE|DOUBLE FORFEITED|DOUBLE LOSS)/i;

  const duoMatchStats = {completed:0, forfeited:0, double:0, byes:0, doubleLoss:0};
  let i = 0;
  while(i < rankingsStart) {
    if(STATUS_RE.test(lines[i])) {
      const statusLine = lines[i].toUpperCase();
      const block = [];
      for(let b=Math.max(0,i-8);b<i;b++) block.push(lines[b]);

      let dashIdx = -1;
      for(let b=block.length-1;b>=0;b--){
        if(block[b]==='-'){dashIdx=b;break;}
      }

      if(dashIdx>=0) {
        const score1str = dashIdx>0 ? block[dashIdx-1] : '';
        const score2str = dashIdx<block.length-1 ? block[dashIdx+1] : '';
        const score1 = parseInt(score1str,10);
        const score2 = parseInt(score2str,10);

        const teamASchool = dashIdx>=2 ? block[dashIdx-2] : '';
        const teamAName = dashIdx>=3 ? block[dashIdx-3] : '';
        const teamBName = dashIdx+2 < block.length ? block[dashIdx+2] : '';
        const teamBSchool = dashIdx+3 < block.length ? block[dashIdx+3] : '';

        const sA = getDisplayName(teamASchool);
        const sB = getDisplayName(teamBSchool);

        if(teamASchool) { ensureSchool(sA); schoolTeams[sA].all.add(teamAName||'teamA_'+i); }
        if(teamBSchool) { ensureSchool(sB); schoolTeams[sB].all.add(teamBName||'teamB_'+i); }

        const isBye = statusLine.startsWith('BYE');
        const isCompleted = statusLine.startsWith('COMPLETED');
        const isDouble = statusLine.startsWith('DOUBLE FORFEITED');
        const isDoubleLoss = statusLine.startsWith('DOUBLE LOSS');
        const isForfeit = statusLine.startsWith('FORFEITED') && !isDouble;

        if(isCompleted) {
          duoMatchStats.completed++;
          if(teamASchool) schoolTeams[sA].competed.add(teamAName||'teamA_'+i);
          if(teamBSchool) schoolTeams[sB].competed.add(teamBName||'teamB_'+i);
        } else if(isBye) {
          duoMatchStats.byes++;
          if(teamASchool) schoolTeams[sA].competed.add(teamAName||'teamA_'+i);
        } else if(isForfeit) {
          duoMatchStats.forfeited++;
          if(!isNaN(score1) && score1===1 && teamASchool) schoolTeams[sA].competed.add(teamAName||'teamA_'+i);
          if(!isNaN(score2) && score2===1 && teamBSchool) schoolTeams[sB].competed.add(teamBName||'teamB_'+i);
        } else if(isDouble) {
          duoMatchStats.double++;
        } else if(isDoubleLoss) {
          duoMatchStats.doubleLoss++;
          duoMatchStats.completed++;
          if(teamASchool) { schoolTeams[sA].competed.add(teamAName||'teamA_'+i); schoolTeams[sA].doubleLoss = true; }
          if(teamBSchool) { schoolTeams[sB].competed.add(teamBName||'teamB_'+i); schoolTeams[sB].doubleLoss = true; }
        }
      }
      i++;
    } else {
      i++;
    }
  }

  if(Object.keys(schoolTeams).length===0){
    errEl.textContent='Could not parse any match data. Make sure the raw text includes match results.';
    errEl.style.display='block';return;
  }

  const schools = {};
  for(const [sn, data] of Object.entries(schoolTeams)){
    schools[sn] = {total: data.all.size, competed: data.competed.size, doubleLoss: data.doubleLoss||false};
  }

  renderSchoolTable(schools,'d-tbody','d-school-count','d', duoMatchStats);
  saveAndRefreshStats(schools,'d');
  document.getElementById('results-duo').style.display='block';
}

function clearDuo(){
  document.getElementById('rawInputDuo').value='';
  document.getElementById('results-duo').style.display='none';
  document.getElementById('errorDuo').style.display='none';
}

function processCombat() {
  const raw = document.getElementById('rawInputCombat').value;
  const errEl = document.getElementById('errorCombat');
  errEl.style.display = 'none';
  if(!raw.trim()){errEl.textContent='No data pasted.';errEl.style.display='block';return;}
  autoDetectWeekLabel(raw);

  const SCHOOL_MAP = [
    {frag:'Grand Forks Red River',                  display:'Grand Forks Red River'},
    {frag:'Eden Prairie High School',               display:'Eden Prairie High School'},
    {frag:'Fargo Public Schools',                   display:'Fargo Public Schools'},
    {frag:'Marty Indian School',                    display:'Marty Indian School'},
    {frag:'Kenmare-Bowbells-Burke Co-op',           display:'Kenmare (Burke Central)'},
    {frag:'Northwestern Area',                      display:'Northwestern Area'},
    {frag:'Mandaree School District',               display:'Mandaree School District'},
    {frag:'Alexander High School',                  display:'Alexander High School'},
    {frag:'Alexander Public Schools',               display:'Alexander High School'},
    {frag:'Mandan',                                 display:'Mandan'},
    {frag:'Sawyer Public School',                   display:'Sawyer Public School'},
    {frag:'Wahpeton Public School',                 display:'Wahpeton'},
    {frag:'Colome School District',                 display:'Colome'},
    {frag:'New Salem Almont',                       display:'New Salem Almont'},
    {frag:'Montpelier',                             display:'Montpelier'},
    {frag:'Stanley',                                display:'Stanley'},
    {frag:'St. John',                               display:'St. John'},
    {frag:'Breckenridge High School',               display:'Breckenridge'},
    {frag:'Dunseith',                               display:'Dunseith'},
    {frag:'West Fargo United',                      display:'West Fargo United'},
    {frag:'South Dakota School of Mines',           display:'South Dakota School of Mines'},
    {frag:'North Dakota State College of Science',  display:'NDSCS'},
    {frag:'Mitchell Technical College',             display:'Mitchell Technical College'},
    {frag:'Bismarck State College',                 display:'Bismarck State College'},
    {frag:'University of Mary',                     display:'University of Mary'},
    {frag:'Minot State',                            display:'Minot State'},
  ];

  function schoolFor(text) {
    let best = null, bestLen = 0;
    for(const s of SCHOOL_MAP) {
      if(text.includes(s.frag) && s.frag.length > bestLen) {
        best = s.display; bestLen = s.frag.length;
      }
    }
    // Handle short school names not in SCHOOL_MAP (e.g. 'Fargo South' shown in bracket)
    if(!best && text.includes('Fargo South')) best = 'Fargo Public Schools';
    return best;
  }

  const schoolData = {};
  function ensure(sd) {
    if(!schoolData[sd]) schoolData[sd] = {allTeams: new Set(), competedTeams: new Set(), doubleLoss: false};
  }
  function addTeam(sd, name) { ensure(sd); schoolData[sd].allTeams.add(name); }
  function addCompeted(sd, name) { ensure(sd); schoolData[sd].allTeams.add(name); schoolData[sd].competedTeams.add(name); }

  const lines = raw.split('\n').map(l => l.trim());

  let rankingsStart = -1;
  for(let i = 0; i < lines.length; i++) {
    if(lines[i] === 'Rankings') { rankingsStart = i; break; }
  }
  const groupLines = rankingsStart >= 0 ? lines.slice(0, rankingsStart) : lines;
  const rankingLines = rankingsStart >= 0 ? lines.slice(rankingsStart + 1) : [];

  const RANK_SKIP = new Set(['No #','Team Name','School','Organization','W-L','W-L?',
    '?','Byes','Game Diff','Points','Points?','Rankings']);

  for(const line of rankingLines) {
    const t = line.trim();
    if(!t) continue;
    if(RANK_SKIP.has(t)) continue;
    if(t.startsWith('DOWNLOAD') || t.startsWith('Group') || t.startsWith('EDIT') ||
       t.startsWith('CONFIGURE') || t.startsWith('Rankings')) continue;

    let bestDisplay = null, bestIdx = Infinity, bestLen = 0;
    for(const s of SCHOOL_MAP) {
      const idx = t.indexOf(s.frag);
      if(idx >= 0 && (s.frag.length > bestLen || (s.frag.length === bestLen && idx < bestIdx))) {
        bestDisplay = s.display; bestIdx = idx; bestLen = s.frag.length;
      }
    }
    if(!bestDisplay || bestIdx <= 0) continue;

    let teamName = t.substring(0, bestIdx).replace(/^\d+\s+/, '').trim();
    if(teamName) addTeam(bestDisplay, teamName);
  }

  const STATUS_RE = /^(COMPLETED|BYE|DOUBLE FORFEITED|DOUBLE LOSS|FORFEITED)\s*\|/i;
  const SCORE_RE = /^\d+$/;

  const combatMatchStats = {completed:0, forfeited:0, double:0, byes:0, doubleLoss:0};
  for(let i = 0; i < groupLines.length; i++) {
    const line = groupLines[i];
    if(!STATUS_RE.test(line)) continue;

    const statusType = line.match(STATUS_RE)[1].toUpperCase();

    const before = [];
    for(let b = i - 1; b >= Math.max(0, i - 15); b--) {
      if(groupLines[b].trim() !== '') before.unshift(groupLines[b].trim());
      if(before.length >= 7) break;
    }
    let dashIdx = -1;
    for(let d = 0; d < before.length; d++) {
      if(before[d] === '-') { dashIdx = d; break; }
    }
    if(dashIdx < 0) continue;

    const scoreA = dashIdx >= 1 ? parseInt(before[dashIdx - 1], 10) : NaN;
    const schoolALine = dashIdx >= 2 ? before[dashIdx - 2] : '';
    const teamAName  = dashIdx >= 3 ? before[dashIdx - 3] : '';
    const scoreB = dashIdx + 1 < before.length ? parseInt(before[dashIdx + 1], 10) : NaN;
    const teamBName  = dashIdx + 2 < before.length ? before[dashIdx + 2] : '';
    const schoolBLine = dashIdx + 3 < before.length ? before[dashIdx + 3] : '';

    const schoolA = schoolFor(schoolALine);
    const schoolB = schoolFor(schoolBLine);

    if(statusType === 'COMPLETED') {
      combatMatchStats.completed++;
      if(schoolA && teamAName) addCompeted(schoolA, teamAName);
      if(schoolB && teamBName) addCompeted(schoolB, teamBName);

    } else if(statusType === 'BYE') {
      combatMatchStats.byes++;
      if(schoolA && teamAName) addCompeted(schoolA, teamAName);

    } else if(statusType === 'FORFEITED') {
      combatMatchStats.forfeited++;
      if(schoolA && teamAName && !isNaN(scoreA) && scoreA > 0) addCompeted(schoolA, teamAName);
      else if(schoolA && teamAName) addTeam(schoolA, teamAName);
      if(schoolB && teamBName && !isNaN(scoreB) && scoreB > 0) addCompeted(schoolB, teamBName);
      else if(schoolB && teamBName) addTeam(schoolB, teamBName);

    } else if(statusType === 'DOUBLE FORFEITED') {
      combatMatchStats.double++;
      if(schoolA && teamAName) addTeam(schoolA, teamAName);
      if(schoolB && teamBName) addTeam(schoolB, teamBName);
    } else if(statusType === 'DOUBLE LOSS') {
      combatMatchStats.doubleLoss++;
      combatMatchStats.completed++;
      if(schoolA && teamAName) { addCompeted(schoolA, teamAName); schoolData[schoolA].doubleLoss = true; }
      if(schoolB && teamBName) { addCompeted(schoolB, teamBName); schoolData[schoolB].doubleLoss = true; }
    }
  }

  if(Object.keys(schoolData).length === 0) {
    errEl.textContent = 'Could not parse data. Make sure you pasted the full page including the Rankings section.';
    errEl.style.display = 'block';
    return;
  }

  const schools = {};
  for(const [sn, data] of Object.entries(schoolData)) {
    if(data.allTeams.size > 0) {
      schools[sn] = { total: data.allTeams.size, competed: data.competedTeams.size, doubleLoss: data.doubleLoss||false };
    }
  }

  renderSchoolTable(schools, 'c-tbody', 'c-school-count', 'c', combatMatchStats);
  saveAndRefreshStats(schools,'c');
  document.getElementById('results-combat').style.display = 'block';
}

function clearCombat(){
  document.getElementById('rawInputCombat').value='';
  document.getElementById('results-combat').style.display='none';
  document.getElementById('errorCombat').style.display='none';
}
