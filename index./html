function autoDetectWeekLabel(raw) {
  const match = raw.match(/(?:(Preseason)\s+)?Week\s+(\d+)\s+Start Date:/i);
  if(match) {
    const pre = match[1] ? 'Preseason ' : 'Season ';
    const label = pre + 'Week ' + match[2];
    const el = document.getElementById('email-week-label');
    if(el) { el.value = label; lsSet('drone_week_label', label); }
  }
}

function lsGet(key) {
  try { return localStorage.getItem(key); } catch(e) { return null; }
}
function lsSet(key, val) {
  try { localStorage.setItem(key, val); } catch(e) {}
}
function lsDel(key) {
  try { localStorage.removeItem(key); } catch(e) {}
}
function lsKeys(prefix) {
  try {
    const keys = [];
    for(let i=0; i<localStorage.length; i++) {
      const k = localStorage.key(i);
      if(k && k.startsWith(prefix)) keys.push(k);
    }
    return keys;
  } catch(e) { return []; }
}

function saveStats(schoolName, tab, competed, total) {
  const key = 'drone_stats:' + schoolName;
  let existing = {};
  try { existing = JSON.parse(lsGet(key) || '{}'); } catch(e) {}
  existing[tab] = {competed, total};
  lsSet(key, JSON.stringify(existing));
}

function loadAllStats() {
  const result = {};
  lsKeys('drone_stats:').forEach(k => {
    try {
      const school = k.replace('drone_stats:', '');
      result[school] = JSON.parse(lsGet(k) || '{}');
    } catch(e) {}
  });
  return result;
}

function saveContacts(contacts) {
  lsSet('drone_contacts', JSON.stringify(contacts));
}

function loadContacts() {
  try { return JSON.parse(lsGet('drone_contacts') || '{}'); } catch(e) { return {}; }
}

function getContact(school) {
  const custom = loadContacts();
  return custom[school] || BUILTIN_CONTACTS[school] || null;
}

function saveAndRefreshStats(schools, pfx) {
  const tabName = pfx==='w' ? 'individual' : pfx==='d' ? 'duo' : 'combat';
  for(const [school, data] of Object.entries(schools)) {
    saveStats(school, tabName, data.competed, data.total);
  }
  refreshSavedStatsList();
  refreshSchoolDropdown();
}

function refreshSchoolDropdown() {
  const stats = loadAllStats();
  const sel = document.getElementById('email-school-select');
  if(!sel) return;
  const current = sel.value;
  sel.innerHTML = '<option value="">— choose a school —</option>';
  Object.keys(stats).sort().forEach(s => {
    const opt = document.createElement('option');
    opt.value = s; opt.textContent = s;
    if(s === current) opt.selected = true;
    sel.appendChild(opt);
  });
}

function refreshSavedStatsList() {
  const stats = loadAllStats();
  const el = document.getElementById('email-saved-list');
  if(!el) return;
  const schools = Object.keys(stats).sort();
  if(schools.length === 0) {
    el.innerHTML = 'No stats saved yet. Parse data on the other tabs first.';
    el.style.color = 'var(--muted)';
    return;
  }
  el.style.color = 'var(--text)';
  el.innerHTML = '';
  schools.forEach(school => {
    const d = stats[school];
    const parts = [];
    if(d.individual) parts.push('Ind: ' + d.individual.competed + '/' + d.individual.total);
    if(d.duo)        parts.push('Duo: ' + d.duo.competed + '/' + d.duo.total);
    if(d.combat)     parts.push('Combat: ' + d.combat.competed + '/' + d.combat.total);
    const row = document.createElement('div');
    row.style.cssText = 'display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border)';
    row.innerHTML = '<span style="color:var(--text);font-weight:600">' + school + '</span>' +
      '<span style="color:var(--muted);font-family:DM Mono,monospace;font-size:12px">' + parts.join('  |  ') + '</span>';
    el.appendChild(row);
  });
}

function onSchoolSelected() {
  const school = document.getElementById('email-school-select').value;
  if(!school) return;
  const c = getContact(school);
  document.getElementById('email-to').value = c ? (c.email || '') : '';
  document.getElementById('email-cc').value = c ? (c.cc || '') : '';
  if(document.getElementById('email-preview-box').style.display !== 'none') {
    generateEmailPreview();
  }
}

function toggleEmailPreview() {
  const box = document.getElementById('email-preview-box');
  if(box.style.display !== 'none') {
    box.style.display = 'none';
  } else {
    generateEmailPreview();
  }
}

function generateEmailPreview() {
  const school = document.getElementById('email-school-select').value;
  const weekLabel = document.getElementById('email-week-label').value.trim();
  if(!school) { alert('Please select a school.'); return false; }
  if(!weekLabel) { alert('Week not detected yet — please parse data from at least one tab.'); return false; }
  const stats = loadAllStats();
  const d = stats[school] || {};
  const indStats = d.individual ? d.individual.competed + '/' + d.individual.total : 'N/A';
  const duoStats = d.duo        ? d.duo.competed        + '/' + d.duo.total        : 'N/A';
  const comStats = d.combat     ? d.combat.competed     + '/' + d.combat.total     : 'N/A';
  const indNotes = document.getElementById('email-ind-notes').value.trim();
  const duoNotes = document.getElementById('email-duo-notes').value.trim();
  const comNotes = document.getElementById('email-com-notes').value.trim();

  let body = 'Hello,\n\n';
  body += 'Here is info about your teams from ' + weekLabel + '. Let us know if you have any questions.\n\n';
  if(indStats !== 'N/A') {
    body += '\u2022 Individual Teams: ' + indStats + ' teams submitted times.';
    if(indNotes) body += '\n      \u25e6 ' + indNotes;
    body += '\n';
  }
  if(duoStats !== 'N/A') {
    body += '\u2022 Duos: ' + duoStats + ' teams submitted times.';
    if(duoNotes) body += '\n      \u25e6 ' + duoNotes;
    body += '\n';
  }
  if(comStats !== 'N/A') {
    body += '\u2022 Combat: ' + comStats + ' teams submitted times.';
    if(comNotes) body += '\n      \u25e6 ' + comNotes;
    body += '\n';
  }
  body += '\n\nContinue to let us know if you want to add or drop students. If you need any help or support, please let us know!\n\n';

  document.getElementById('email-preview-text').textContent = body;
  document.getElementById('email-preview-box').style.display = 'block';
  return body;
}

function openOutlookDraft() {
  const body = generateEmailPreview();
  if(!body) return;
  const to      = encodeURIComponent(document.getElementById('email-to').value.trim());
  const cc      = encodeURIComponent(document.getElementById('email-cc').value.trim());
  const school  = document.getElementById('email-school-select').value;
  const week    = document.getElementById('email-week-label').value.trim();
  const subject = encodeURIComponent('Drone Racing ' + week + ' Recap');
  const bodyEnc = encodeURIComponent(body);
  window.location.href = 'mailto:' + to + '?cc=' + cc + '&subject=' + subject + '&body=' + bodyEnc;
}

function clearSavedStats() {
  if(!confirm('Clear all saved stats? This cannot be undone.')) return;
  lsKeys('drone_stats:').forEach(k => lsDel(k));
