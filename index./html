<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Drone Racing Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  [data-theme="dark"] {
    --bg:#0f0d0d;--bg2:#1a1414;--surface:#1e1717;--border:#2e2222;
    --accent:#c0161c;--accent-h:#e01e25;--accent2:#ff6b35;
    --text:#f0e8e8;--text-inv:#ffffff;--muted:#6b5555;
    --green:#3ecf8e;--yellow:#f5a623;--blue:#3e9fcf;--glow:rgba(192,22,28,0.08);
    --pill-full-bg:rgba(62,207,142,0.12);--pill-partial-bg:rgba(245,166,35,0.12);
    --pill-none-bg:rgba(192,22,28,0.15);--btn-primary-text:#ffffff;
    --shadow:0 2px 16px rgba(0,0,0,0.4);
  }
  [data-theme="light"] {
    --bg:#ffffff;--bg2:#faf5f5;--surface:#ffffff;--border:#e8d8d8;
    --accent:#c0161c;--accent-h:#a01015;--accent2:#e05a20;
    --text:#1a0a0a;--text-inv:#ffffff;--muted:#9e7070;
    --green:#1a9e6a;--yellow:#c47d00;--blue:#1a7aaf;--glow:rgba(192,22,28,0.05);
    --pill-full-bg:rgba(26,158,106,0.1);--pill-partial-bg:rgba(196,125,0,0.1);
    --pill-none-bg:rgba(192,22,28,0.08);--btn-primary-text:#ffffff;
    --shadow:0 2px 12px rgba(0,0,0,0.08);
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  html{transition:background 0.3s,color 0.3s;}
  body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;padding:40px 20px;transition:background 0.3s,color 0.3s;}
  body::before{content:'';position:fixed;top:-200px;left:-200px;width:700px;height:700px;background:radial-gradient(circle,var(--glow) 0%,transparent 70%);pointer-events:none;z-index:0;}
  .container{max-width:940px;margin:0 auto;position:relative;z-index:1;}

  /* HEADER */
  header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;}
  .header-left{}
  .title-line{display:flex;align-items:center;gap:16px;margin-bottom:4px;}
  .wolf-icon{width:88px;height:88px;flex-shrink:0;object-fit:contain;}
  h1{font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:2px;color:var(--accent);line-height:1;transition:color 0.3s;}
  .subtitle{font-size:12px;color:var(--muted);font-family:'DM Mono',monospace;letter-spacing:1px;text-transform:uppercase;padding-left:2px;}

  /* THEME TOGGLE */
  .theme-toggle{display:flex;align-items:center;gap:10px;background:var(--surface);border:1.5px solid var(--border);border-radius:50px;padding:6px 14px 6px 10px;cursor:pointer;transition:all 0.2s;box-shadow:var(--shadow);flex-shrink:0;margin-top:6px;}
  .theme-toggle:hover{border-color:var(--accent);}
  .toggle-track{width:36px;height:20px;background:var(--border);border-radius:10px;position:relative;transition:background 0.3s;flex-shrink:0;}
  [data-theme="dark"] .toggle-track{background:var(--accent);}
  .toggle-thumb{position:absolute;top:3px;left:3px;width:14px;height:14px;border-radius:50%;background:#fff;transition:transform 0.3s;box-shadow:0 1px 4px rgba(0,0,0,0.3);}
  [data-theme="dark"] .toggle-thumb{transform:translateX(16px);}
  .toggle-label{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--muted);user-select:none;white-space:nowrap;}

  /* TABS */
  .tab-bar{display:flex;gap:0;margin-bottom:28px;border-bottom:2px solid var(--border);}
  .tab-btn{background:transparent;border:none;border-bottom:3px solid transparent;margin-bottom:-2px;padding:10px 22px;font-family:'DM Mono',monospace;font-size:12px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);cursor:pointer;transition:all 0.2s;}
  .tab-btn:hover{color:var(--text);}
  .tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
  .tab-panel{display:none;}
  .tab-panel.active{display:block;}

  /* PASTE AREA */
  .paste-area{background:var(--surface);border:1.5px solid var(--border);border-radius:10px;padding:20px;margin-bottom:20px;transition:border-color 0.2s,background 0.3s;box-shadow:var(--shadow);}
  .paste-area:focus-within{border-color:var(--accent);}
  .paste-label{font-size:11px;font-family:'DM Mono',monospace;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:10px;}
  textarea{width:100%;height:160px;background:transparent;border:none;outline:none;color:var(--text);font-family:'DM Mono',monospace;font-size:12px;resize:vertical;line-height:1.6;}
  textarea::placeholder{color:var(--muted);}

  /* BUTTONS */
  .btn-row{display:flex;gap:12px;margin-bottom:28px;}
  button{cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:700;font-size:14px;letter-spacing:0.5px;border:none;border-radius:8px;padding:12px 28px;transition:all 0.15s;}
  .btn-primary{background:var(--accent);color:var(--btn-primary-text);}
  .btn-primary:hover{background:var(--accent-h);transform:translateY(-1px);box-shadow:0 4px 16px rgba(192,22,28,0.35);}
  .btn-clear{background:transparent;border:1.5px solid var(--border);color:var(--muted);}
  .btn-clear:hover{border-color:var(--accent);color:var(--accent);}

  /* STAT CARDS */
  .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
  @media(max-width:680px){.stats-grid{grid-template-columns:repeat(2,1fr);}}
  .stat-card{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:18px 20px;position:relative;overflow:hidden;box-shadow:var(--shadow);transition:background 0.3s,border-color 0.3s;}
  .stat-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;border-radius:0 0 12px 12px;}
  .stat-card.c-red::after{background:var(--accent);}
  .stat-card.c-green::after{background:var(--green);}
  .stat-card.c-yellow::after{background:var(--yellow);}
  .stat-card.c-orange::after{background:var(--accent2);}
  .stat-card.c-blue::after{background:var(--blue);}
  .stat-card.c-blue .stat-value{color:var(--blue);}
  .stat-card.c-white::after{background:var(--text);}
  .stat-card.c-white .stat-value{color:var(--text);}
  .stat-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:10px;}
  .stat-value{font-family:'Bebas Neue',sans-serif;font-size:40px;line-height:1;letter-spacing:1px;transition:color 0.3s;}
  .stat-card.c-red .stat-value{color:var(--accent);}
  .stat-card.c-green .stat-value{color:var(--green);}
  .stat-card.c-yellow .stat-value{color:var(--yellow);}
  .stat-card.c-orange .stat-value{color:var(--accent2);}
  .stat-sub{font-size:11px;color:var(--muted);margin-top:4px;font-family:'DM Mono',monospace;}

  /* DONUTS */
  .donut-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:28px;}
  @media(max-width:580px){.donut-row{grid-template-columns:1fr;}}
  .donut-card{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;padding:22px 24px;display:flex;align-items:center;gap:22px;box-shadow:var(--shadow);transition:background 0.3s,border-color 0.3s;}
  .donut-wrap{position:relative;flex-shrink:0;width:80px;height:80px;}
  .donut-wrap svg{transform:rotate(-90deg);}
  .donut-center{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:1px;}
  .donut-info{flex:1;}
  .donut-title{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
  .donut-big{font-family:'Bebas Neue',sans-serif;font-size:30px;line-height:1;letter-spacing:1px;}
  .donut-desc{font-size:12px;color:var(--muted);margin-top:4px;}

  /* TABLE */
  .results-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;}
  .results-title{font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:1px;color:var(--text);}
  .table-wrap{background:var(--surface);border:1.5px solid var(--border);border-radius:12px;overflow:hidden;box-shadow:var(--shadow);transition:background 0.3s,border-color 0.3s;}
  table{width:100%;border-collapse:collapse;}
  thead tr{border-bottom:1.5px solid var(--border);}
  [data-theme="dark"] thead tr{background:#160e0e;}
  [data-theme="light"] thead tr{background:#fdf0f0;}
  th{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);padding:12px 16px;text-align:left;}
  th:last-child,td:last-child{text-align:right;}
  tbody tr{border-bottom:1px solid var(--border);transition:background 0.1s;}
  tbody tr:last-child{border-bottom:none;}
  tbody tr:hover{background:rgba(192,22,28,0.04);}
  td{padding:13px 16px;font-size:14px;}
  .school-name{font-weight:700;color:var(--text);}
  .fraction{font-family:'DM Mono',monospace;font-size:13px;}
  .pill{display:inline-block;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:700;font-family:'DM Mono',monospace;}
  .pill-full{background:var(--pill-full-bg);color:var(--green);}
  .pill-partial{background:var(--pill-partial-bg);color:var(--yellow);}
  .pill-none{background:var(--pill-none-bg);color:var(--accent);}
  .bar-wrap{width:90px;height:5px;background:var(--border);border-radius:3px;overflow:hidden;display:inline-block;vertical-align:middle;margin-right:8px;}
  .bar-fill{height:100%;border-radius:3px;}

  /* ERROR */
  .error-msg{background:var(--pill-none-bg);border:1px solid rgba(192,22,28,0.3);border-radius:8px;padding:14px 18px;color:var(--accent);font-size:13px;font-family:'DM Mono',monospace;margin-bottom:20px;display:none;}

  /* RULES PANEL */
  .table-footer{padding:12px 16px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:10px;}
  .btn-rules{align-self:flex-start;background:transparent;border:1px solid var(--border);color:var(--muted);font-size:12px;font-family:'DM Mono',monospace;font-weight:500;padding:5px 14px;border-radius:20px;letter-spacing:0.5px;cursor:pointer;transition:all 0.2s;}
  .btn-rules:hover{border-color:var(--accent);color:var(--accent);}
  .rules-panel{display:none;font-size:12px;font-family:'DM Mono',monospace;color:var(--muted);line-height:1.8;background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:14px 16px;}
  .rules-panel strong{color:var(--text);}
  .rules-panel em{color:var(--accent);font-style:normal;font-weight:500;}

  #results-weekly,#results-duo,#results-combat{display:none;}

  .home-btn {
    font-family: 'Barlow Condensed', 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #9899a8;
    background: transparent;
    border: 1px solid #2a2a32;
    border-radius: 3px;
    padding: 6px 14px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.15s;
    margin-right: 12px;
  }
  .home-btn:hover {
    color: #f0f0f0;
    border-color: #666878;
  }
</style>
</head>
<body>
<style>
  #pinGate {
    position: fixed; inset: 0; background: #0a0a0c; z-index: 9999;
    display: flex; align-items: center; justify-content: center;
    font-family: Arial, sans-serif;
  }
  #pinGate.hidden { display: none; }
  .pin-box {
    background: #18181d; border: 1px solid #2a2a32; border-radius: 8px;
    padding: 40px 48px; display: flex; flex-direction: column;
    align-items: center; gap: 20px; width: 340px;
  }
  .pin-logo {
    width: 280px; height: 86px; overflow: hidden; position: relative;
  }
  .pin-logo img {
    position: absolute;
    width: 291px;
    height: 291px;
    top: -103px;
    left: -6px;
    mix-blend-mode: screen;
  }
  .pin-title {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase; color: #666878;
    margin-top: -8px; font-family: Arial, sans-serif;
  }
  .pin-label {
    font-size: 11px; font-weight: 600;
    letter-spacing: 1.5px; text-transform: uppercase; color: #9899a8;
    align-self: flex-start; font-family: Arial, sans-serif;
  }
  #pinInput {
    width: 100%; background: #0a0a0c; border: 1px solid #2a2a32; color: #f0f0f0;
    border-radius: 3px; padding: 10px 12px; font-size: 22px; letter-spacing: 8px;
    text-align: center; font-family: monospace; box-sizing: border-box;
  }
  #pinInput:focus { outline: none; border-color: #e5001e; }
  #pinError {
    font-size: 12px; letter-spacing: 1px;
    text-transform: uppercase; color: #e5001e; min-height: 16px;
    font-family: Arial, sans-serif;
  }
  #pinSubmit {
    width: 100%; background: #e5001e; color: #fff; border: none; border-radius: 3px;
    padding: 11px; font-size: 14px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase; cursor: pointer;
    transition: background 0.15s; font-family: Arial, sans-serif;
  }
  #pinSubmit:hover { background: #ff3c54; }
</style>

<div id="pinGate">
  <div class="pin-box">
    <div class="pin-logo">
      <img src="data:image/png;base64," alt="Fenworks">
    </div>
    <div class="pin-title">Admin Access Required</div>
    <div class="pin-label">Enter PIN</div>
    <input type="password" id="pinInput" maxlength="6" placeholder="••••"
      oninput="document.getElementById('pinError').textContent=''"
      onkeydown="if(event.key==='Enter')checkPin()">
    <div id="pinError"></div>
    <button id="pinSubmit" onclick="checkPin()">Unlock</button>
  </div>
</div>

<script>
(function() {
  const PIN = '1029';
  const KEY = 'fw_admin_auth';
  if (sessionStorage.getItem(KEY) === '1') {
    document.getElementById('pinGate').classList.add('hidden');
  }
  window.checkPin = function() {
    const val = document.getElementById('pinInput').value.trim();
    if (val === PIN) {
      sessionStorage.setItem(KEY, '1');
      document.getElementById('pinGate').classList.add('hidden');
    } else {
      document.getElementById('pinError').textContent = 'Incorrect PIN';
      document.getElementById('pinInput').value = '';
      document.getElementById('pinInput').focus();
    }
  };
})();
</script>

<div class="container">

  <header>
    <a href="https://eninja8.github.io/Fenworks-Hub/" class="header-left" style="text-decoration:none;" title="Back to Fenworks Hub">
      <div class="title-line">
        <img src="data:image/png;base64," class="wolf-icon" alt="Wolf Logo">
        <h1>Drone Tracker</h1>
      </div>
      <div class="subtitle">Individual // Duo // Combat Submission Tracker</div>
    </a>
    <div class="theme-toggle" onclick="toggleTheme()" title="Toggle light/dark mode">
      <div class="toggle-track"><div class="toggle-thumb"></div></div>
      <span class="toggle-label" id="themeLabel">Dark</span>
    </div>
  </header>

  
  <div class="tab-bar">
    <button class="tab-btn active" onclick="switchTab('weekly',this)">⏱ Drone Individual</button>
    <button class="tab-btn" onclick="switchTab('duo',this)">🤝 Drone Duo</button>
    <button class="tab-btn" onclick="switchTab('combat',this)">⚔️ Drone Combat</button>
    <button class="tab-btn" onclick="switchTab('email',this)">✉️ Email</button>
  </div>

  
  <div id="tab-weekly" class="tab-panel active">
    <div class="paste-area">
      <div class="paste-label">Raw Data Input — Drone Individual</div>
      <textarea id="rawInputWeekly" placeholder="Paste the raw copied text from the Drone Individual results page here..."></textarea>
    </div>
    <div class="btn-row">
      <button class="btn-primary" onclick="processWeekly()">⚡ Parse Individual Data</button>
      <button class="btn-clear" onclick="clearWeekly()">Clear</button>
    </div>
    <div class="error-msg" id="errorWeekly"></div>
    <div id="results-weekly">
      <div class="stats-grid">
        <div class="stat-card c-green"><div class="stat-label">Matches Completed</div><div class="stat-value" id="w-matches-completed">0</div><div class="stat-sub">submitted a time</div></div>
        <div class="stat-card c-red"><div class="stat-label">Matches Not Completed</div><div class="stat-value" id="w-matches-not">0</div><div class="stat-sub">did not submit</div></div>
        <div class="stat-card c-green" style="display:none"><div class="stat-label">Participation Rate</div><div class="stat-value" id="w-part">0%</div><div class="stat-sub">of all teams</div></div>
        <div class="stat-card c-red" style="display:none"><div class="stat-label">Forfeit Rate</div><div class="stat-value" id="w-forfeit">0%</div><div class="stat-sub">did not submit</div></div>
      </div>
      <div class="donut-row">
        <div class="donut-card">
          <div class="donut-wrap"><svg width="80" height="80" viewBox="0 0 80 80"><circle cx="40" cy="40" r="32" fill="none" stroke="var(--border)" stroke-width="9"/><circle id="w-donut-part" cx="40" cy="40" r="32" fill="none" stroke="var(--green)" stroke-width="9" stroke-dasharray="0 201" stroke-linecap="round"/></svg><div class="donut-center" style="color:var(--green)" id="w-donut-part-pct">0%</div></div>
          <div class="donut-info"><div class="donut-title">Participation Rate</div><div class="donut-big" style="color:var(--green)" id="w-donut-part-frac">0/0</div><div class="donut-desc">teams submitted a time</div></div>
        </div>
        <div class="donut-card">
          <div class="donut-wrap"><svg width="80" height="80" viewBox="0 0 80 80"><circle cx="40" cy="40" r="32" fill="none" stroke="var(--border)" stroke-width="9"/><circle id="w-donut-forf" cx="40" cy="40" r="32" fill="none" stroke="var(--accent)" stroke-width="9" stroke-dasharray="0 201" stroke-linecap="round"/></svg><div class="donut-center" style="color:var(--accent)" id="w-donut-forf-pct">0%</div></div>
          <div class="donut-info"><div class="donut-title">Forfeit Rate</div><div class="donut-big" style="color:var(--accent)" id="w-donut-forf-frac">0/0</div><div class="donut-desc">teams did not submit</div></div>
        </div>
      </div>
      <div class="results-header">
        <div class="results-title">By School</div>
        <div style="font-family:'DM Mono',monospace;font-size:12px;color:var(--muted)"><span id="w-school-count" style="color:var(--accent)">0</span> schools</div>
      </div>
      <div class="table-wrap">
        <table><thead><tr><th>#</th><th>School</th><th>Submitted / Total</th><th>Progress</th><th>Status</th></tr></thead><tbody id="w-tbody"></tbody></table>
        <div class="table-footer">
          <button class="btn-rules" onclick="toggleRules('w-rules','this')" id="w-rules-btn">ℹ Rules</button>
          <div class="rules-panel" id="w-rules">
            <strong>How Drone Individual data is parsed:</strong><br>
            • Each entry with a numeric time (any number, including 999.999) counts as <em>submitted</em>.<br>
            • Entries where the time field is blank count as <em>not submitted</em>.<br>
            • Burke Central is sorted/grouped under <em>Kenmare</em>.<br>
            • Schools are sorted A–Z. Participation = submitted ÷ total.
          </div>
        </div>
      </div>
    </div>
  </div>

  
  <div id="tab-duo" class="tab-panel">
    <div class="paste-area">
      <div class="paste-label">Raw Data Input — Drone Duo Bracket</div>
      <textarea id="rawInputDuo" placeholder="Paste the raw copied text from the Drone Duo bracket page here (matches + rankings)..."></textarea>
    </div>
    <div class="btn-row">
      <button class="btn-primary" onclick="processDuo()">⚡ Parse Duo Data</button>
      <button class="btn-clear" onclick="clearDuo()">Clear</button>
    </div>
    <div class="error-msg" id="errorDuo"></div>
    <div id="results-duo">
      <div class="stats-grid">
        <div class="stat-card c-white"><div class="stat-label">Total Teams</div><div class="stat-value" id="d-total">0</div><div class="stat-sub">registered this week</div></div>
        <div class="stat-card c-green"><div class="stat-label">Teams Competed</div><div class="stat-value" id="d-competed">0</div><div class="stat-sub">played at least 1 match</div></div>
        <div class="stat-card c-white"><div class="stat-label">Matches Created</div><div class="stat-value" id="d-matches-created">0</div><div class="stat-sub">total matches</div></div>
        <div class="stat-card c-green"><div class="stat-label">Matches Completed</div><div class="stat-value" id="d-matches-completed">0</div><div class="stat-sub">fully played / double loss</div></div>
        <div class="stat-card c-red"><div class="stat-label">Matches Forfeited</div><div class="stat-value" id="d-matches-forfeited">0</div><div class="stat-sub">one team no-show</div></div>
        <div class="stat-card c-red"><div class="stat-label">Double Forfeits</div><div class="stat-value" id="d-matches-double">0</div><div class="stat-sub">both teams no-show</div></div>
        <div class="stat-card c-blue"><div class="stat-label">Byes</div><div class="stat-value" id="d-matches-byes">0</div><div class="stat-sub">no opponent available</div></div>
